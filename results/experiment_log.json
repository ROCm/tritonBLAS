        "fix": "Move reset_fn() onto matmul_stream via with torch.cuda.stream(stream): reset_fn()"
      },
      "results": {
        "before_fix": {
          "gemm_alone_warm_ms": 1.228,
          "gemm_rotating_ms": 2.016,
          "warm_rotating_gap": "59%",
