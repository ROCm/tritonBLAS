    {
      "experiment_id": "exp_001_l2_baseline",
      "timestamp": "2026-03-19T15:26:51.726335",
      "hypothesis": "Establish baseline L2 hit rates for GEMM running in isolation across sizes",
      "configuration": {
        "docker": "tritonblas-research:latest (ROCm 7.2, PyTorch 2.12.0, Triton 3.6.0)",
        "backend": "ws (work-stealing)",
        "gpu": "MI300X (304 CUs, 8 XCDs)",
        "counters": "TCC_HIT_sum, TCC_MISS_sum",
        "sizes": [
          1024,
          2048,
          4096,
          8192,
          16384
        ]
      },
      "results": {
        "l2_hit_rates": {
          "1024": 79.3,
          "2048": 63.1,
          "4096": 80.2,
          "8192": 78.1,
          "16384": 78.8
        },
        "timings_ms": {
          "1024": 0.277,
          "2048": 0.351,
          "4096": 0.488,
          "8192": 2.033,
          "16384": 14.488
